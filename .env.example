# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_at_least_32_random_characters_here

# ─── SMTP Email (Gmail recommended) ─────────────────────────────────────────
# Gmail App Password: myaccount.google.com → Security → 2-Step → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=TikTok Coins <your@gmail.com>

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Debug (optional) ────────────────────────────────────────────────────────
# Enables GET /api/debug-db when set — omit in production to disable the endpoint
DEBUG_API_KEY=

# Set to 'true' to show requestId in signup error UI (useful for debugging with logs)
NEXT_PUBLIC_SHOW_REQUEST_ID=
